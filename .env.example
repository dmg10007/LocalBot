# ── Discord ────────────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token

# ── llama-server (llama.cpp) ───────────────────────────────────────────────────────────────────
# Full path to the llama-server binary, or just "llama-server" if on PATH.
LLAMA_SERVER_EXECUTABLE=llama-server
# Full path to your GGUF model file. REQUIRED.
LLAMA_SERVER_MODEL_PATH=/path/to/your/model.gguf
# Host and port llama-server listens on (localhost only is strongly recommended).
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8080
# GPU layers. -1 = all layers on GPU; 0 = CPU only; N = offload N layers.
# For Llama-3.2-3B-Instruct-Q4_K_M on CPU: leave at 0.
# With a GPU (e.g. RTX 3060 12GB): set to -1 to offload everything.
LLAMA_SERVER_N_GPU_LAYERS=0
# Context window in tokens.
# Llama 3.2 3B supports up to 131072 tokens, but in practice:
#   - 4096 = fast, low RAM, good for chat
#   - 8192 = better for long conversations or large tool results
# Do NOT set above what your RAM can hold (Q4_K_M 3B uses ~2GB for weights;
# each 4096 ctx costs ~200-400MB additional RAM depending on batch size).
LLAMA_SERVER_CTX_SIZE=4096
# CPU threads. 0 = auto-detect physical cores. Set explicitly if you want to
# limit CPU usage (e.g. LLAMA_SERVER_THREADS=4 on a 16-core machine).
LLAMA_SERVER_THREADS=0
# Extra CLI flags passed verbatim to llama-server.
# Useful flags for Llama 3.2 3B Instruct:
#   --flash-attn          Faster attention; requires llama.cpp built with FA support
#   --no-mmap             Load model fully into RAM (more stable on Windows)
#   --parallel 1          Limit to 1 concurrent request slot (good for single-user bot)
#   --cont-batching       Enable continuous batching (default on newer builds)
# Example: LLAMA_SERVER_EXTRA_ARGS=--flash-attn --no-mmap --parallel 1
#
# DO NOT add --chat-template here. The GGUF file embeds the correct template
# for Llama 3.2 Instruct. Overriding it causes <|eot_id|> tokens to leak
# into responses as literal text (e.g. a 'd\n' prefix on every reply).
LLAMA_SERVER_EXTRA_ARGS=

# ── Search ────────────────────────────────────────────────────────────────────────────
# Brave Search API key (https://api.search.brave.com). Leave blank to disable.
BRAVE_API_KEY=
# Number of search results to inject into context.
SEARCH_RESULT_COUNT=5

# ── Timeouts ────────────────────────────────────────────────────────────────────────────
# These three values form a budget hierarchy:
#   REQUEST_DEADLINE_SECONDS is the outer wall-clock limit for an entire user
#   request. It must be >= MODEL_TIMEOUT_SECONDS + (TOOL_TIMEOUT_SECONDS *
#   MAX_TOOL_ITERATIONS) or the deadline will always fire before tools finish.
#
# Max seconds a single model call may run.
# Llama 3.2 3B Q4_K_M on CPU typically responds in 10-60s depending on
# response length and thread count. 120s is a safe ceiling.
MODEL_TIMEOUT_SECONDS=120
# Max seconds a single tool/search call may run.
TOOL_TIMEOUT_SECONDS=30
# Total wall-clock budget per user request (model + tools combined).
# With defaults: 120 + (30 * 5) = 270s of work fits inside the 300s budget.
REQUEST_DEADLINE_SECONDS=300

# ── History & behaviour ──────────────────────────────────────────────────────────
# Number of past messages kept in context per user.
# Lower = less context poisoning risk with small models; higher = better
# multi-turn coherence. 6-10 is the sweet spot for 3B models.
MAX_HISTORY_MESSAGES=6
# Maximum tool-call iterations before forcing a final reply.
MAX_TOOL_ITERATIONS=5

# ── Storage ─────────────────────────────────────────────────────────────────────────────
DATABASE_PATH=storage/localbot.sqlite3
AUDIT_LOG_PATH=logs/audit.jsonl

# ── Scheduler ───────────────────────────────────────────────────────────────────────────
SCHEDULER_POLL_SECONDS=15
SCHEDULER_MAX_JOBS=20
SCHEDULER_MAX_JOBS_PER_USER=5
