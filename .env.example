# ─────────────────────────────────────────────────────────────────────────────
# LocalBot — .env.example
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here           # optional; speeds up slash-command sync

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_pat_here         # needs: repo, read:org (minimum)
GITHUB_DEFAULT_OWNER=your_github_username     # default owner for GitHub tool calls
# Comma-separated allowlist of "owner" or "owner/repo" the LLM may write to.
# Empty → falls back to GITHUB_DEFAULT_OWNER (if set) → denies all writes.
GITHUB_ALLOWED_REPOS=your_github_username/LocalBot

# ── OpenWebUI auth ────────────────────────────────────────────────────────────
# REQUIRED — shared secret between OpenWebUI and the localbot-webui bridge.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_API_KEY=                                # no default — must be set

# ── Groq API (optional — fast cloud inference fallback) ───────────────────────
# Free tier: 30 req/min, 6 000 req/day on llama-3.1-8b-instant.
# When set, non-sensitive queries (no filesystem/scheduler/diagnostics context)
# are routed to Groq for sub-100 ms TTFT. Public tool calls (web_search,
# reddit_search, get_current_time) are also executed via Groq function calling.
# Leave blank to disable. Get a key at: https://console.groq.com/keys
GROQ_API_KEY=
# Fast model — used for general and coding slot queries.
# GROQ_MODEL=llama-3.1-8b-instant
# Heavy model — used for reasoning slot queries (design, analysis, trade-offs).
# GROQ_MODEL_HEAVY=llama-3.3-70b-versatile

# ── Cloudflare Workers AI (optional — free-tier search summarisation) ─────────
# Used only for web_search result summarisation when set, not for chat replies.
# Get values at: https://dash.cloudflare.com/ → Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Model slots ───────────────────────────────────────────────────────────────
# Paths are CONTAINER paths mapped from C:\Llama\Models via the volume mount:
#   C:\Llama\Models  →  /models  (read-only inside the container)
#
# Hardware profile: i5-10400H, 16 GB DDR4-2933 DC, no discrete GPU
# Memory budget for models (Windows + Docker + services consume ~6-7 GB):
#   Available for models: ~9-10 GB  (one slot active at a time)
#
# Recommended model stack — ordered by tok/s on this hardware:
#
# SLOT_GENERAL — general chat, search, scheduling (loaded at boot, always on)
#   Best choice:  Qwen2.5-3B-Instruct Q4_K_M  (~1.9 GB, ~12-20 tok/s)
#   Alternative:  Qwen3.5-4B-Instruct Q4_K_M  (~2.5 GB, ~10-16 tok/s)
SLOT_GENERAL_MODEL=/models/your-general-model-q4_k_m.gguf
# SLOT_GENERAL_PORT=8080                      # default: 8080 (or LLAMA_SERVER_PORT)

# SLOT_CODING — code generation (loaded on demand via hot-swap)
#   Best choice:  Qwen3-Coder-4B-A1.3B Q4_K_M (~2.5 GB, MoE — only 1.3B active params
#                 per token, ~14-22 effective tok/s, strong coding quality)
#   Alternative:  Qwen2.5-Coder-3B Q4_K_M     (~1.9 GB, ~14-22 tok/s)
# SLOT_CODING_MODEL=/models/your-coding-model-q4_k_m.gguf
# SLOT_CODING_PORT=8081                       # default: 8081

# SLOT_REASONING — chain-of-thought / reasoning (loaded on demand)
#   Best choice:  Qwen2.5-7B-Instruct Q5_K_M  (~5.5 GB, ~5-8 tok/s, best quality)
#   Alternative:  Qwen2.5-7B-Instruct Q4_K_M  (~4.5 GB, ~6-9 tok/s)
#   Note: general and reasoning CAN share the same GGUF — only the system prompt differs,
#         so switching between them is instant with no model reload.
# SLOT_REASONING_MODEL=/models/your-reasoning-model-q4_k_m.gguf
# SLOT_REASONING_PORT=8082                    # default: 8082

# ── Speculative decoding (optional — adds ~1.5-2× effective tok/s on DENSE models) ─
# A small draft model generates tokens speculatively; the main model verifies
# them in a single pass. 70-80% acceptance rate typical → ~1.6-1.8× speedup
# on dense models (SLOT_GENERAL_MODEL, SLOT_REASONING_MODEL).
# CAVEAT: benchmarks show this is often NET NEGATIVE on MoE models (e.g. the
# recommended SLOT_CODING_MODEL above) — drafted tokens still require loading
# fresh expert-weight slices, eating the bandwidth savings. Benchmark before
# relying on it for the coding slot; it's safest enabled on general/reasoning only.
# RAM cost: ~0.5-0.7 GB for a 0.5B-1B Q4_K_M draft model.
# Recommended: Qwen2.5-0.5B-Instruct Q4_K_M (~0.4 GB)
#              SmolLM2-1.7B-Instruct Q4_K_M  (~1.1 GB, higher acceptance rate)
# Setting this alone is sufficient — llamacpp_server.py automatically appends
# the --spec-type/--model-draft/--spec-draft-n-max flags. Do NOT also add
# --model-draft to LLAMA_SERVER_EXTRA_ARGS below; that would pass it twice.
# SLOT_DRAFT_MODEL=/models/your-draft-model-q4_k_m.gguf

# ── llama-server tuning ───────────────────────────────────────────────────────
# Context size. Overrides LLAMA_ARG_CTX_SIZE set in docker-compose.yml.
# RAM cost ≈ 0.5 MB per 1k tokens (fp16 KV) or 0.25 MB (q8_0 KV, default).
# 2048 is the safe default; 4096 works if no draft model and reasoning slot unused.
LLAMA_CTX_SIZE=2048

# Extra args forwarded verbatim to llama-server. The defaults below are tuned
# for the i5-10400H and are applied by docker-compose.yml.
# To enable speculative decoding, set SLOT_DRAFT_MODEL above instead — do not
# add --model-draft/--spec-type here, it would duplicate the auto-appended flags.
LLAMA_SERVER_EXTRA_ARGS=--flash-attn on --cache-type-k q8_0 --cache-type-v q8_0 --ubatch-size 512

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Absolute path INSIDE the container that the filesystem tools are confined to.
# The docker-compose volume maps ./sandbox → /app/sandbox (read-write).
SANDBOX_ROOT=/app/sandbox

# ── Brave Search ──────────────────────────────────────────────────────────────
# BRAVE_API_KEY=your_brave_api_key_here

# ── Search tuning (optional overrides) ───────────────────────────────────────
# Fetch more results and page content for richer summaries.
# SEARCH_RESULT_COUNT=8       # default: 8 (up from 5)
# SEARCH_FETCH_COUNT=5        # default: 5 (up from 3) — pages to fetch full content from
# SEARCH_FETCH_CHARS=2000     # default: 2000 (up from 1500) — chars extracted per page

# ── Inference tuning (optional overrides) ────────────────────────────────────
# MODEL_TEMPERATURE=0.3
# MODEL_TIMEOUT_SECONDS=120
# MAX_HISTORY_MESSAGES=12
# MAX_TOOL_ITERATIONS=5

# ── Misc (optional) ───────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
