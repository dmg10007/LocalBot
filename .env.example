# ── Discord ──────────────────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token

# ── llama-server (llama.cpp) ───────────────────────────────────────────────────────────────────────────────────────
LLAMA_SERVER_EXECUTABLE=llama-server
LLAMA_SERVER_MODEL_PATH=/path/to/your/model.gguf
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8080
# -1 = all GPU; 0 = CPU only; N = offload N layers.
LLAMA_SERVER_N_GPU_LAYERS=0
# 4096 = fast + low RAM. Raise to 8192+ for larger models or richer search context.
LLAMA_SERVER_CTX_SIZE=4096
# 0 = auto-detect physical cores.
LLAMA_SERVER_THREADS=0
# Extra flags passed verbatim to llama-server.
# Examples: --flash-attn --no-mmap --parallel 1 --reasoning-budget 512
# DO NOT add --chat-template — the GGUF embeds the correct template.
LLAMA_SERVER_EXTRA_ARGS=
# Override auto-detected model family. Use if the bot logs the wrong family.
# Valid values: gemma | llama | mistral | qwen | deepseek | phi
# Leave blank for auto-detection (recommended).
LLAMA_SERVER_MODEL_FAMILY=

# ── Model behaviour ───────────────────────────────────────────────────────────────────────────────────────
# Temperature: 0.1 = very focused/deterministic, 1.0 = creative/varied.
# 0.3 is a good default for tool-calling and factual chat.
# Try 0.1-0.2 for smaller models that tend to ramble.
MODEL_TEMPERATURE=0.3

# ── Search ──────────────────────────────────────────────────────────────────────────────────
BRAVE_API_KEY=
SEARCH_RESULT_COUNT=5
SEARCH_FETCH_COUNT=3
SEARCH_FETCH_CHARS=1500
SEARCH_FETCH_TIMEOUT_SECONDS=8

# ── Timeouts ──────────────────────────────────────────────────────────────────────────────────────
MODEL_TIMEOUT_SECONDS=120
TOOL_TIMEOUT_SECONDS=30
REQUEST_DEADLINE_SECONDS=300

# ── History & behaviour ──────────────────────────────────────────────────────────────────────────
MAX_HISTORY_MESSAGES=6
MAX_TOOL_ITERATIONS=3

# ── Storage ───────────────────────────────────────────────────────────────────────────────────────
DATABASE_PATH=storage/localbot.sqlite3
AUDIT_LOG_PATH=logs/audit.jsonl

# ── Scheduler ───────────────────────────────────────────────────────────────────────────────────────
SCHEDULER_POLL_SECONDS=15
SCHEDULER_MAX_JOBS=20
SCHEDULER_MAX_JOBS_PER_USER=5

# ── Rate limiting ────────────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_SECONDS=5
MAX_INPUT_LENGTH=1000
