# ─────────────────────────────────────────────────────────────────────────────
# LocalBot — .env.example
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
 DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here           # optional; speeds up slash-command sync

# ── GitHub MCP ──────────────────────────────────────────────────────────────────
 GITHUB_TOKEN=ghp_your_github_pat_here         # needs: repo, read:org (minimum)

# ── OpenWebUI auth ──────────────────────────────────────────────────────────────
 WEBUI_API_KEY=localbot                        # shared secret between OpenWebUI and the bridge

# ── llama.cpp model slots ─────────────────────────────────────────────────────────
# Paths are CONTAINER paths (mapped from C:\Llama\Models via the volume mount).
# Use Q4_K_M quants on this hardware — best quality/RAM tradeoff without a GPU.
#
#   4B model  (e.g. Phi-3-mini, Llama-3.2-3B):  ~3–4 GB RAM at Q4_K_M → fits comfortably
#   7B model  (e.g. Mistral-7B, Llama-3-8B):    ~5–6 GB RAM at Q4_K_M → tight but works
#   13B model (e.g. Llama-2-13B):               ~9 GB RAM at Q4_K_M  → leaves <4 GB for rest; NOT recommended
#
SLOT_0_MODEL=/models/your-model-q4_k_m.gguf
SLOT_0_NAME=default

# Add more slots if your bot supports model switching:
# SLOT_1_MODEL=/models/another-model-q4_k_m.gguf
# SLOT_1_NAME=fast

# ── llama-server context size ───────────────────────────────────────────────────────
# Overrides LLAMA_ARG_CTX_SIZE in docker-compose.yml.
# RAM cost per context token ≈ 0.5 MB per 1k tokens (varies by model).
# 4096 is safe. 8192 is workable with a 7B Q4 if nothing else is running.
LLAMA_CTX_SIZE=4096

# ── Misc ────────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# STORAGE_PATH=/app/storage
