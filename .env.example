# ── Required ────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Model slots ─────────────────────────────────────────────────────────────
# General slot: lightweight always-on model (Llama 3.2 3B, Qwen 2.5 3B, etc.)
# Falls back to LLAMA_SERVER_MODEL_PATH for backwards compatibility.
SLOT_GENERAL_MODEL=models/llama-3.2-3b-instruct-q4_k_m.gguf
SLOT_GENERAL_PORT=8080

# Coding slot: code-optimised model (Qwen2.5-Coder 7B, etc.)
# Leave blank to disable — coding requests will use the general slot.
SLOT_CODING_MODEL=models/qwen2.5-coder-7b-instruct-q4_k_m.gguf
SLOT_CODING_PORT=8081

# Reasoning slot: chain-of-thought model (DeepSeek-R1 8B, etc.)
# Leave blank to disable — reasoning requests will use the general slot.
SLOT_REASONING_MODEL=models/deepseek-r1-8b-q4_k_m.gguf
SLOT_REASONING_PORT=8082

# Seconds of inactivity before a heavy slot is unloaded and general reloads.
# Set to 0 to disable idle unloading entirely.
IDLE_UNLOAD_SECONDS=120

# ── llama-server settings ────────────────────────────────────────────────────
LLAMA_SERVER_EXECUTABLE=llama-server
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_N_GPU_LAYERS=0
LLAMA_SERVER_CTX_SIZE=4096
LLAMA_SERVER_THREADS=0
# LLAMA_SERVER_EXTRA_ARGS=--mlock

# ── Coding workspace ─────────────────────────────────────────────────────────
# Absolute path to the local folder the bot is allowed to read/write.
# The bot refuses any path that escapes this directory.
# Leave blank to disable local filesystem tools.
SANDBOX_ROOT=/home/user/projects

# GitHub personal access token (repo scope) for remote workspace tools.
# Leave blank to disable GitHub tools.
GITHUB_TOKEN=ghp_your_token_here

# Default GitHub owner/org used when not specified in a request.
GITHUB_DEFAULT_OWNER=your_github_username

# ── Search ───────────────────────────────────────────────────────────────────
BRAVE_API_KEY=your_brave_api_key_here
SEARCH_RESULT_COUNT=5
SEARCH_FETCH_COUNT=3
SEARCH_FETCH_CHARS=1500
SEARCH_FETCH_TIMEOUT_SECONDS=8

# ── Inference ────────────────────────────────────────────────────────────────
MODEL_TIMEOUT_SECONDS=120
MODEL_TEMPERATURE=0.3
TOOL_TIMEOUT_SECONDS=30
REQUEST_DEADLINE_SECONDS=300
MAX_HISTORY_MESSAGES=12
MAX_TOOL_ITERATIONS=5

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_PATH=storage/localbot.sqlite3
AUDIT_LOG_PATH=logs/audit.jsonl

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_MAX_JOBS=20
SCHEDULER_MAX_JOBS_PER_USER=5

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_SECONDS=5
MAX_INPUT_LENGTH=1000

# ── Update checker ───────────────────────────────────────────────────────────
LLAMA_UPDATE_CHECK=true
LLAMA_UPDATE_AUTO=false
LLAMA_UPDATE_CHECK_TIMEOUT_SECONDS=10
LLAMA_UPDATE_PROMPT_TIMEOUT_SECONDS=30
