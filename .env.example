# ─────────────────────────────────────────────────────────────────────────────
# LocalBot — .env.example
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here           # optional; speeds up slash-command sync

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_pat_here         # needs: repo, read:org (minimum)
GITHUB_DEFAULT_OWNER=your_github_username     # default owner for GitHub tool calls
# Comma-separated allowlist of "owner" or "owner/repo" the LLM may write to.
# Empty → falls back to GITHUB_DEFAULT_OWNER (if set) → denies all writes.
GITHUB_ALLOWED_REPOS=your_github_username/LocalBot

# ── OpenWebUI auth ────────────────────────────────────────────────────────────
# REQUIRED — shared secret between OpenWebUI and the localbot-webui bridge.
# Generate with PowerShell:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_API_KEY=                                # no default — must be set

# ── Model slots ───────────────────────────────────────────────────────────────
# Paths are CONTAINER paths mapped from C:\Llama\Models via the volume mount:
#   C:\Llama\Models  →  /models  (read-only inside the container)
#
# Hardware guidance for i5-10400H, 16 GB RAM, no GPU (Q4_K_M recommended):
#   4B model  (~3–4 GB): fits comfortably alongside other services
#   7B model  (~5–6 GB): tight but works; recommended max for general slot
#   13B model (~9 GB):   leaves <4 GB for everything else — NOT recommended
#
# SLOT_GENERAL — primary slot: general conversation + tool calling
SLOT_GENERAL_MODEL=/models/your-general-model-q4_k_m.gguf
# SLOT_GENERAL_PORT=8080                      # default: 8080 (or LLAMA_SERVER_PORT)

# SLOT_CODING  — secondary slot: code generation (loaded on demand, hot-swapped)
# SLOT_CODING_MODEL=/models/your-coding-model-q4_k_m.gguf
# SLOT_CODING_PORT=8081                       # default: 8081

# SLOT_REASONING — tertiary slot: chain-of-thought / reasoning tasks
# SLOT_REASONING_MODEL=/models/your-reasoning-model-q4_k_m.gguf
# SLOT_REASONING_PORT=8082                    # default: 8082

# ── llama-server tuning ───────────────────────────────────────────────────────
# Overrides LLAMA_ARG_CTX_SIZE set in docker-compose.yml.
# RAM cost ≈ 0.5 MB per 1k tokens. 4096 is safe; 8192 works with a 7B Q4
# if no other heavy services are running.
LLAMA_CTX_SIZE=4096

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Absolute path INSIDE the container that the filesystem tools are confined to.
# The docker-compose volume maps ./sandbox → /app/sandbox (read-write).
SANDBOX_ROOT=/app/sandbox

# ── Brave Search (optional) ───────────────────────────────────────────────────
# BRAVE_API_KEY=your_brave_api_key_here

# ── Inference tuning (optional overrides) ────────────────────────────────────
# MODEL_TEMPERATURE=0.3
# MODEL_TIMEOUT_SECONDS=120
# MAX_HISTORY_MESSAGES=12
# MAX_TOOL_ITERATIONS=5

# ── Misc (optional) ───────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
